# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_ALLOW_PUBLIC_SIGNUP=false
ALLOW_PUBLIC_SIGNUP=false

# LLM — chat, suggestions, prep, post-meeting (Groq / OpenRouter / any OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Embeddings — Knowledge Base semantic search (OPTIONAL).
# Leave blank to run the KB on keyword search only; add later to enable vectors.
# Falls back to OPENAI_API_KEY if EMBEDDING_API_KEY is unset.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# Encryption at rest for Microsoft OAuth tokens (OPTIONAL).
# 32-byte secret (hex, base64, or any passphrase). If unset, tokens are stored as-is.
APP_ENCRYPTION_KEY=

# Microsoft Graph (org / Microsoft 365 accounts)
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=

# Google Calendar (works with a normal Gmail account; Teams join link is read from the event)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Web → realtime bot server (used by the live copilot + briefing "Join")
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# App URL (used to build Microsoft OAuth redirect when MICROSOFT_REDIRECT_URI is unset)
NEXT_PUBLIC_APP_URL=

# Realtime bot server
PORT=4000
CORS_ORIGIN=http://localhost:3000
